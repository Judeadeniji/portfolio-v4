---
import { getEntry } from 'astro:content';
import { marked } from 'marked';

const profileEntry = await getEntry('profile', 'main');
const profileData = profileEntry!.data;

const name = profileData.name;
const avatarUrl = profileData.avatarUrl;
const location = profileData.contact.location;
const email = profileData.contact.email;
const calLink = profileData.contact.cal;
const twitterHandle = profileData.twitterHandle;
const twitterUrl = `https://x.com/${twitterHandle}`;
const bio = profileData.bio;
---
  <header class="mb-16 font-mono text-[13px]" aria-label="Profile Details">
    <div class="space-y-4 mb-8">
      <div class="flex items-center gap-2.5">
        <span class="text-green-500 font-bold opacity-80">~</span>
        <span class="text-muted-foreground/50">$</span>
        <span class="text-foreground">whoami --profile</span>
      </div>
      
      <div class="flex flex-row gap-4 sm:gap-6 items-start pl-0 sm:pl-6">
        <img
          src={avatarUrl}
          alt={`Profile avatar for ${name}`}
          loading="eager"
          fetchpriority="high"
          class="w-16 h-16 sm:w-20 sm:h-20 rounded-lg object-cover border border-border shrink-0"
        />
        <div class="space-y-3 text-muted-foreground grow">
          <div class="grid grid-cols-[70px_1fr] sm:grid-cols-[100px_1fr] gap-x-2 gap-y-1.5 sm:gap-2">
            <span class="text-foreground/40">name:</span> 
            <h1 class="text-foreground font-medium text-[13px] m-0 p-0 leading-none self-center">{name}</h1>
            
            <span class="text-foreground/40">role:</span> 
            <span>Product Engineer</span>
            
            <span class="text-foreground/40">location:</span> 
            <span>{location}</span>
            
            <span class="text-foreground/40">pronouns:</span> 
            <span>he/him</span>
          </div>
          
          <div class="pt-1 sm:pt-2 flex flex-wrap gap-x-4 sm:gap-x-6 gap-y-2">
            <a href={`/adeniji-oluwaferanmi-resume.pdf`} target="_blank" class="hover:text-foreground hover:underline underline-offset-4 decoration-border">--resume</a>
            <a href={`https://github.com/Judeadeniji`} class="hover:text-foreground hover:underline underline-offset-4 decoration-border">--github</a>
            <a href={twitterUrl} class="hover:text-foreground hover:underline underline-offset-4 decoration-border">--twitter</a>
            {calLink && <a href={calLink} class="hover:text-foreground hover:underline underline-offset-4 decoration-border">--book-call</a>}
            <a href={`mailto:${email}`} class="hover:text-foreground hover:underline underline-offset-4 decoration-border">--email</a>
          </div>
        </div>
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="sr-only">Bio</h2>
      <div class="flex items-center gap-2.5" aria-hidden="true">
        <span class="text-green-500 font-bold opacity-80">~</span>
        <span class="text-muted-foreground/50">$</span>
        <span class="text-foreground">cat bio.md</span>
      </div>
      
      <div class="pl-0 sm:pl-6 text-muted-foreground leading-relaxed prose prose-zinc dark:prose-invert prose-sm prose-p:my-2 prose-a:text-foreground prose-a:underline hover:prose-a:text-muted-foreground" set:html={marked.parse(bio)}>
      </div>
    </div>
  </header>
