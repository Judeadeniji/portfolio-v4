---
import { getCollection, type CollectionEntry } from "astro:content";
import { markdownToHtml } from "satteri";

const rawExperience = await getCollection("experience");
const experiences = rawExperience.sort((a, b) => a.data.order - b.data.order).map(e => ({
  ...e.data,
  descriptionHtml: markdownToHtml(e.data.description).html,
  highlightsHtml: e.data.highlights ? e.data.highlights.map(h => markdownToHtml(h).html) : []
}));
---
  <section id="experience" class="space-y-4 mb-16 font-mono text-[13px]" aria-label="Experience History">
    <h2 class="sr-only">Experience</h2>
    <div class="flex items-center gap-2.5 mb-6" aria-hidden="true">
      <span class="text-green-500 font-bold opacity-80">~</span>
      <span class="text-muted-foreground/50">$</span>
      <span class="text-foreground">cat history.log</span>
    </div>

    <div class="pl-0 sm:pl-6 space-y-10">
      {experiences.map((exp) => (
        <div class="space-y-3">
          <div class="text-foreground font-medium flex flex-col sm:flex-row sm:justify-between gap-1">
            <span>[{exp.period}] {exp.role} @ {exp.company}</span>
            <span class="text-muted-foreground/50">{exp.location}</span>
          </div>
          <div class="text-muted-foreground leading-relaxed prose prose-zinc dark:prose-invert prose-sm prose-p:my-0 prose-a:text-foreground prose-a:underline hover:prose-a:text-muted-foreground max-w-none" set:html={exp.descriptionHtml}>
          </div>
          {exp.highlights && exp.highlights.length > 0 && (
            <details class="group pt-1">
              <summary class="cursor-pointer text-muted-foreground hover:text-foreground transition-colors list-none flex items-center gap-2 select-none w-max [&::-webkit-details-marker]:hidden">
                <span class="text-green-500 font-bold opacity-80">~</span>
                <span class="text-muted-foreground/50">$</span>
                <span class="underline underline-offset-4 decoration-border transition-colors">./show_highlights.sh</span>
                <span class="text-[9px] opacity-50 transition-transform duration-200 group-open:rotate-180 ml-1">▼</span>
              </summary>
              <div class="text-muted-foreground opacity-80 pl-4 border-l border-border/40 space-y-2 mt-3">
                {exp.highlightsHtml.map((highlightHtml: string) => (
                  <div class="flex gap-2">
                    <span>></span>
                    <div class="prose prose-zinc dark:prose-invert prose-sm prose-p:my-0 prose-a:text-foreground prose-a:underline hover:prose-a:text-muted-foreground max-w-none text-xs" set:html={highlightHtml}></div>
                  </div>
                ))}
              </div>
            </details>
          )}
        </div>
      ))}
    </div>
  </section>
