---
import { getEntry } from 'astro:content';
import VisitorCounter from './VisitorCounter';

const profileEntry = await getEntry('profile', 'main');
const profileData = profileEntry!.data;
const name = profileData.name;
const currentYear = new Date().getFullYear();
---
  <footer class="mt-8 mb-4 font-mono text-[12px] sm:text-[13px] text-muted-foreground">
    <div class="border-t border-border/30 border-dashed pt-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex flex-col items-start gap-1">
        <div class="flex items-center gap-2">
          <span class="text-green-500 font-bold opacity-80">~</span>
          <span class="text-muted-foreground/50">$</span>
          <span>exit</span>
        </div>
        <div class="opacity-60 pl-6">
          Session ended. © {currentYear} {name.toLowerCase().replace(/\s+/g, '')}.
        </div>
      </div>

      <div class="flex items-center gap-2 opacity-60 pl-6 sm:pl-0">
        <span>[ Visitors: <VisitorCounter client:only="react" /> ]</span>
      </div>
    </div>
  </footer>
