---
import "../styles/global.css";
import CustomCursor from "../components/CustomCursor.astro";
import GlobalTerminal from "../components/GlobalTerminal.tsx";
import Footer from "@/components/Footer.astro";

interface Props {
    title: string;
    description?: string;
    image?: string;
    schema?: Record<string, any>;
}

const { 
    title, 
    description = "Jude Adeniji - Product Engineer building interactive web applications.",
    image = "/og-image.png",
    schema
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url);

const defaultSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Oluwaferanmi Adeniji",
    "jobTitle": "Product Engineer",
    "url": canonicalURL.href,
    "image": new URL(image, canonicalURL).href,
    "sameAs": [
        "https://github.com/Judeadeniji",
        "https://www.linkedin.com/in/feranmi-adeniji",
        "https://x.com/iam_feranmi_"
    ]
};

const finalSchema = schema || defaultSchema;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="canonical" href={canonicalURL} />
        <meta name="generator" content={Astro.generator} />
        <meta name="google-site-verification" content="T-4rFKnZQGBoANf2eim4xp3di2mWXE71OcLGbtBr8pE" />
        
        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(image, canonicalURL)} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={new URL(image, canonicalURL)} />
        <meta name="robots" content="index, follow" />
        <script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
            rel="stylesheet"
        />
        <title>{title}</title>
    </head>
    <body
        class="bg-background text-foreground font-sans min-h-screen flex flex-col antialiased relative selection:bg-foreground selection:text-background"
    >
        <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 z-100 bg-background border border-border px-4 py-2 text-sm font-mono text-foreground font-medium rounded-md">
            Skip to content
        </a>
        
        <CustomCursor />
        {/* Navbar */}
        <nav class="fixed top-0 left-0 right-0 z-50">
            <div
                class="pointer-events-none absolute inset-x-0 top-0 h-10 bg-background mask-[linear-gradient(to_bottom,black_80%,transparent)]"
            >
            </div>
            <div class="relative w-full max-w-4xl mx-auto pl-4 pr-0 sm:px-6 lg:px-0">
                <div class="flex items-center justify-between h-7 sm:h-8">
                    <div class="flex items-center gap-3 sm:gap-5 text-[12px] sm:text-[13px] font-mono text-muted-foreground overflow-x-auto no-scrollbar py-2 w-full mask-[linear-gradient(to_right,black_85%,transparent)] sm:mask-none">
                        <div class="items-center gap-2.5 shrink-0 hidden sm:flex">
                          <span class="text-green-500 font-bold opacity-80">~</span>
                          <span class="opacity-50">$</span>
                        </div>
                        <a
                            class="shrink-0 hover:text-foreground hover:underline underline-offset-4 decoration-border transition-colors"
                            href="/">cd /home</a
                        >
                        <a
                            class="shrink-0 hover:text-foreground hover:underline underline-offset-4 decoration-border transition-colors"
                            href="/blog">cd /blog</a
                        >
                        <a
                            class="shrink-0 hover:text-foreground hover:underline underline-offset-4 decoration-border transition-colors"
                            href="/#projects">./projects</a
                        >
                        <a
                            class="shrink-0 hover:text-foreground hover:underline underline-offset-4 decoration-border transition-colors"
                            href="/#experience">./experience</a
                        >
                        <a
                            class="shrink-0 hover:text-foreground hover:underline underline-offset-4 decoration-border transition-colors pr-8 sm:pr-0"
                            href="/#contact">./contact</a
                        >
                    </div>
                </div>
            </div>
        </nav>

        <main
            id="main-content"
            class="relative z-10 w-full max-w-4xl mx-auto px-6 lg:px-0 pt-18 sm:pt-32 pb-16 grow outline-none"
            tabindex="-1"
        >
            <slot />
            <Footer />
        </main>
        
        <GlobalTerminal client:load />
    </body>
</html>
