---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getEntry, render } from "astro:content";
import { marked } from "marked";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  posts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

  return posts.map((post: any, index: number) => {
    return {
      params: { slug: post.id },
      props: { 
        post,
        prevPost: index + 1 < posts.length ? posts[index + 1] : null,
        nextPost: index - 1 >= 0 ? posts[index - 1] : null,
      },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);

const profileEntry = await getEntry('profile', 'main');
const author = profileEntry!.data;
---

<Layout title={`${post.data.title} | ${author.name}`} description={post.data.description}>
  <div class="mb-12">
    <a href="/blog" class="font-mono text-[13px] text-muted-foreground hover:text-foreground transition-colors mb-8 inline-flex items-center gap-2">
      <span class="text-green-500 font-bold opacity-80">~</span> $ cd ..
    </a>
    
    <header class="mb-12 font-mono">
      <div class="flex items-center gap-2.5 mb-4 text-[13px]">
        <span class="text-green-500 font-bold opacity-80">~</span>
        <span class="text-muted-foreground/50">$</span>
        <span class="text-foreground">cat {post.id}.mdx</span>
      </div>
      <h1 class="text-2xl font-bold tracking-tight text-foreground mb-4 font-sans">{post.data.title}</h1>
      <div class="text-[13px] text-muted-foreground flex flex-wrap items-center gap-4 opacity-70">
        <span>[{post.data.category}]</span>
        <span>{new Date(post.data.date).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        })}</span>
      </div>
    </header>
    
    {headings.length > 0 && (
      <details  class="group mb-12 font-mono text-[13px]">
        <summary class="cursor-pointer text-muted-foreground hover:text-foreground transition-colors list-none flex items-center gap-2 select-none w-max [&::-webkit-details-marker]:hidden">
          <span class="text-green-500 font-bold opacity-80">~</span>
          <span class="text-muted-foreground/50">$</span>
          <span class="underline underline-offset-4 decoration-border transition-colors">./show_toc.sh</span>
          <span class="text-[9px] opacity-50 transition-transform duration-200 group-open:rotate-180 ml-1">▼</span>
        </summary>
        <div class="text-muted-foreground opacity-80 pl-4 border-l border-border/40 space-y-2.5 mt-4">
          <div class="text-foreground/40 text-[11px] uppercase tracking-widest mb-1">Table of Contents</div>
          {headings.filter(h => h.depth <= 3).map(heading => (
            <a href={`#${heading.slug}`} class={`block hover:text-foreground transition-colors ${heading.depth === 3 ? 'pl-4' : ''}`}>
              <span class="opacity-50 mr-2">#</span>
              <span class="hover:underline underline-offset-4 decoration-border">{heading.text}</span>
            </a>
          ))}
        </div>
      </details>
    )}
    
    <article class="relative prose prose-zinc dark:prose-invert prose-p:text-[15px] prose-p:leading-relaxed prose-headings:font-medium max-w-none mb-16 custom-prose">
      <Content />
    </article>

    {/* Author Section */}
<div class="border-t border-border pt-8 mt-12 mb-12 font-mono">
  <div class="flex items-center gap-2.5 mb-4 text-[13px]">
    <span class="text-green-500 font-bold opacity-80">~</span>
    <span class="text-muted-foreground/50">$</span>
    <span class="text-foreground">whoami --author</span>
  </div>
  <div class="flex items-start gap-4">
    <img src={author.avatarUrl} alt={author.name} class="w-12 h-12 rounded-md border border-border ring-2 ring-background shadow-sm shrink-0" />
    <div>
      <div class="text-[15px] font-medium text-foreground leading-none mb-0.5">{author.name}</div>
      <div class="text-[13px] text-muted-foreground/50 mb-3">Product Engineer</div>
      <div class="text-[14px] text-muted-foreground leading-relaxed max-w-lg mb-4 prose prose-zinc dark:prose-invert prose-sm prose-p:my-0 prose-a:text-foreground prose-a:underline prose-a:underline-offset-4 hover:prose-a:text-muted-foreground" set:html={marked.parse(author.bio)} />
      <div class="flex flex-wrap gap-4 text-[13px] text-muted-foreground">
        <a href={`https://x.com/${author.twitterHandle}`} target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">--twitter</a>
        <a href={author.contact.github} target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">--github</a>
        <a href={author.contact.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">--linkedin</a>
        <a href={author.contact.cal} target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">--book-call</a>
        <a href={`mailto:${author.contact.email}`} class="hover:text-foreground transition-colors">--email</a>
      </div>
    </div>
  </div>
</div>

    {/* Pagination */}
    <div class="border-t border-border/40 border-dashed pt-8 font-mono text-[13px] space-y-3">
      {prevPost && (
        <a href={`/blog/${prevPost.id}`} class="group flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 text-muted-foreground hover:text-foreground transition-colors">
          <div class="flex items-center gap-2.5">
            <span class="text-green-500 font-bold opacity-80">~</span>
            <span class="text-muted-foreground/50">$</span>
            <span class="group-hover:underline underline-offset-4 decoration-border">./{prevPost.id}.mdx</span>
          </div>
          <span class="opacity-40 hidden sm:inline-block"># Previous</span>
        </a>
      )}
      {nextPost && (
        <a href={`/blog/${nextPost.id}`} class="group flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 text-muted-foreground hover:text-foreground transition-colors">
          <div class="flex items-center gap-2.5">
            <span class="text-green-500 font-bold opacity-80">~</span>
            <span class="text-muted-foreground/50">$</span>
            <span class="group-hover:underline underline-offset-4 decoration-border">./{nextPost.id}.mdx</span>
          </div>
          <span class="opacity-40 hidden sm:inline-block"># Next</span>
        </a>
      )}
    </div>
  </div>
</Layout>

<style is:global>
  .custom-prose a {
    color: var(--color-foreground);
    text-underline-offset: 4px;
    transition: color 150ms ease-in-out;
  }
  
  .custom-prose h1 a,
  .custom-prose h2 a,
  .custom-prose h3 a,
  .custom-prose h4 a,
  .custom-prose h5 a,
  .custom-prose h6 a {
    text-decoration: none !important;
  }
  
  .custom-prose a:hover {
    color: var(--color-muted-foreground);
  }
</style>
