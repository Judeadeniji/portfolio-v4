---
import Layout from "../layouts/Layout.astro";
import ProfileHeader from "../components/ProfileHeader.astro";
import Contributions from "../components/Contributions.astro";
import TechStack from "../components/TechStack.astro";
import FeaturedProjects from "../components/FeaturedProjects.astro";
import Experience from "../components/Experience.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { getEntry } from "astro:content";

const profileEntry = await getEntry("profile", "main");
const name = profileEntry!.data.name;
---

<Layout title={`${name} | Portfolio`}>
  <ProfileHeader />
  <Contributions />
  <TechStack />
  <FeaturedProjects />
  <Experience />
  <Contact />
  <Footer />
</Layout>
